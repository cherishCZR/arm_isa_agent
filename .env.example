# ================================================================
# ARM ISA Agent — Environment Configuration
# ================================================================
# Copy this file to .env and adjust values.
# CLI options (--preset / --model / --api-key / --base-url)
# take precedence over these environment variables.
#
# Quick start:
#   Local dev:  ARM_ISA_LLM_PRESET=local
#   Demo:       ARM_ISA_LLM_PRESET=deepseek
# ================================================================

# ---- LLM Preset (one of: local, deepseek, or empty for manual) ----
# local:    Ollama qwen3:8b @ localhost:11434 (dev)
# deepseek: DeepSeek API deepseek-chat (demo/prod)
ARM_ISA_LLM_PRESET=local

# ---- LLM Manual Config (ignored if preset matches) ----------------
# ARM_ISA_LLM_PROVIDER=openai
# ARM_ISA_LLM_MODEL=gpt-4o
# ARM_ISA_LLM_API_KEY=
# ARM_ISA_LLM_BASE_URL=
# ARM_ISA_LLM_TEMPERATURE=0.0

# ---- Data Paths ---------------------------------------------------
# ARM_ISA_DATA_DIR=data
# ARM_ISA_RAW_XML_DIR=ISA_A64_xml_A_profile-2025-03/ISA_A64_xml_A_profile-2025-03
# ARM_ISA_SQLITE_DB_PATH=data/sqlite/isa_kb.db
# ARM_ISA_CHROMA_PERSIST_DIR=data/chroma

# ---- Embedding ----------------------------------------------------
# ARM_ISA_EMBEDDING_MODEL_NAME=BAAI/bge-m3
# ARM_ISA_EMBEDDING_DEVICE=cpu

# ---- ETL ----------------------------------------------------------
# ARM_ISA_ETL_BATCH_SIZE=100
# ARM_ISA_ETL_MAX_WORKERS=4

# ---- Logging ------------------------------------------------------
# ARM_ISA_LOG_LEVEL=INFO
# ARM_ISA_LOG_FORMAT=console
