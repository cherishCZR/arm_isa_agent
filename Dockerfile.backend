# ── ARM ISA Agent Backend Dockerfile ──
FROM python:3.12-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY pyproject.toml ./
RUN pip install --no-cache-dir -e ".[api]" || pip install --no-cache-dir fastapi uvicorn pydantic pydantic-settings structlog lxml chromadb langchain langchain-openai langgraph

# Application code
COPY src/ ./src/
COPY data/ ./data/
COPY scripts/ ./scripts/

# Environment
ENV PYTHONPATH=/app/src
ENV ARM_ISA_DATA_DIR=/app/data
ENV ARM_ISA_API_HOST=0.0.0.0
ENV ARM_ISA_API_PORT=8000

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "arm_isa_agent.api.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8000"]
